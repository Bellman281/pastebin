# Copy to .env (git-ignored) or export these. All are optional; defaults shown.

# Address to bind.
# APP_BIND_ADDR=127.0.0.1:8080

# Max concurrently-handled connections (backpressure beyond this).
# MAX_CONNECTIONS=10000

# Max request-body size in bytes (larger -> 413).
# MAX_BODY_BYTES=65536

# Per-read inactivity timeout in seconds (idle keep-alive close / stalled -> 408).
# REQUEST_TIMEOUT_SECS=30

# Grace period for in-flight connections to drain on shutdown, in seconds.
# SHUTDOWN_GRACE_SECS=10

# Log filter, e.g. info, debug, tcp_actor_server=debug.
# RUST_LOG=info
