# Copy to .env and adjust. All values have sane defaults if unset.

# Address the HTTP server binds to.
APP_BIND_ADDR=127.0.0.1:8080

# Max request body size in bytes.
MAX_BODY_BYTES=16384

# SQLite connection URL. Use a FILE path for real data (created if missing).
# WARNING: `sqlite::memory:` gives each pooled connection its own private DB, so
# writes are not shared across connections. For an in-memory DB, also set
# DATABASE_MAX_CONNECTIONS=1 (or use `sqlite::memory:?cache=shared`).
DATABASE_URL=sqlite://links.db

# Max pooled DB connections (bounds memory under load).
DATABASE_MAX_CONNECTIONS=5

# Base URL used to build the full short link in responses, e.g. https://sho.rt
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Per-request timeout in seconds (slow requests are cut off with 408).
REQUEST_TIMEOUT_SECS=10

# Max in-flight requests; excess requests wait (bounded by the timeout above).
MAX_CONCURRENT_REQUESTS=1024

# tracing filter. Use e.g. info,tower_http=debug to see per-request traces.
RUST_LOG=info
