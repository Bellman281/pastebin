# Copy to .env and adjust. All values have sane defaults if unset.

# Address the HTTP server binds to. (8090 so it can run alongside the shortener.)
APP_BIND_ADDR=127.0.0.1:8090

# Max request body size in bytes (pastes are larger than URLs; default 1 MiB).
MAX_BODY_BYTES=1048576

# SQLite connection URL. Use a FILE path for real data (created if missing).
DATABASE_URL=sqlite://pastes.db

# Max pooled DB connections (bounds memory under load).
DATABASE_MAX_CONNECTIONS=5

# Base URL used to build the paste URL in responses, e.g. https://paste.example
PUBLIC_BASE_URL=http://127.0.0.1:8090

# tracing filter. Use e.g. info,tower_http=debug to see per-request traces.
RUST_LOG=info
